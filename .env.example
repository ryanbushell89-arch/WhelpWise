# ============================================================
# WhelpWise — Environment Variable Template
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# The public HTTPS URL of your app (no trailing slash).
# Used to auto-register the Stripe webhook endpoint on startup.
APP_URL=https://app.whelpwise.com

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/whelpwise

# ── Clerk Authentication ──────────────────────────────────────
# From https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Frontend (Vite) ───────────────────────────────────────────
# Same value as CLERK_PUBLISHABLE_KEY above
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Port the API server listens on — Vite dev proxy forwards /api/* here.
# Must match PORT above. Only needed in development.
API_PORT=5000

# Optional: set to https://yourapp.com/api/__clerk to proxy Clerk
# through your domain (recommended for custom domains).
# Leave blank to let the browser talk directly to Clerk.
# VITE_CLERK_PROXY_URL=https://app.whelpwise.com/api/__clerk

# URL base path for the frontend (default: /)
BASE_PATH=/

# ── Dev Bypasses ─────────────────────────────────────────────
# Set to "true" to skip Stripe subscription check in development.
# Leave unset or set to "false" in production.
# DISABLE_SUBSCRIPTION_CHECK=true

# ── Stripe ───────────────────────────────────────────────────
# From https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...

# From https://dashboard.stripe.com → Developers → Webhooks
# Create a webhook pointing to: https://yourapp.com/api/stripe/webhook
# Listen for: customer.subscription.created/updated/deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google Cloud Storage ─────────────────────────────────────
# Option A: Path to a service account JSON key file (local/Docker volume mount)
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcs-keyfile.json

# Option B: Base64-encoded service account JSON (useful for env-only deployments)
# Generate with: base64 -i service-account.json | tr -d '\n'
# GCS_KEYFILE_JSON=eyJ0eXBlIjoic2VydmljZV...

# Your GCS bucket name
GCS_BUCKET_NAME=whelpwise-uploads

# Comma-separated GCS paths for publicly readable objects
PUBLIC_OBJECT_SEARCH_PATHS=/whelpwise-uploads/public

# GCS path prefix for private (breeder/puppy) uploads
PRIVATE_OBJECT_DIR=/whelpwise-uploads/private
